flowchart TB
    subgraph INPUT["Input tensor: 3 x 15 x 15"]
        P0["Plane 0<br/>current player's stones<br/><small>15 x 15</small>"]
        P1["Plane 1<br/>opponent stones<br/><small>15 x 15</small>"]
        P2["Plane 2<br/>side-to-move<br/><small>15 x 15</small>"]
    end

    subgraph FILTER["One learned filter"]
        K0["3 x 3 slice<br/>for plane 0"]
        K1["3 x 3 slice<br/>for plane 1"]
        K2["3 x 3 slice<br/>for plane 2"]
        SUM["weighted sum<br/>27 weights + bias"]
        K0 --> SUM
        K1 --> SUM
        K2 --> SUM
    end

    M1["Feature map #1<br/><small>15 x 15</small>"]
    M2["Feature map #2<br/><small>15 x 15</small>"]
    MDOTS["..."]
    M64["Feature map #64<br/><small>15 x 15</small>"]
    OUT["Output tensor<br/>64 x 15 x 15"]

    P0 --> K0
    P1 --> K1
    P2 --> K2
    SUM --> M1
    SUM -. repeated with different learned weights .-> M2
    SUM -. repeated .-> MDOTS
    SUM -. repeated .-> M64
    M1 --> OUT
    M2 --> OUT
    MDOTS --> OUT
    M64 --> OUT

    NOTE["3 x 3 is the local window size.<br/>64 is the number of separate filters.<br/>padding = 1 keeps every map 15 x 15."]
    OUT --> NOTE

