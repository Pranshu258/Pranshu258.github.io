%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#f0f4f8", "primaryTextColor": "#1e293b", "primaryBorderColor": "#94a3b8", "lineColor": "#475569", "secondaryColor": "#f8fafc", "tertiaryColor": "#f0f4f8", "background": "#f9f6ee", "mainBkg": "#f0f4f8", "nodeBorder": "#94a3b8", "clusterBkg": "#f8fafc", "titleColor": "#1e293b", "edgeLabelBackground": "#f9f6ee", "edgeLabelColor": "#1e293b"}}}%%
flowchart TD
    A(["model(input) called"]):::start --> B["Accelerate's forward<br/>wrapper intercepts the call"]:::process
    B --> C["pre_forward hook fires"]:::hook

    C --> D{"Offloading<br/>enabled?"}:::decision
    D -- No --> E["Move inputs to execution device (GPU)"]:::process
    D -- Yes --> F["Loop over module weights"]:::process

    F --> G["Look up weight<br/>in weights_map"]:::lookup
    G --> H{"Where is the<br/>weight stored?"}:::decision
    H -- "CPU state dict" --> I["Read tensor<br/>from RAM"]:::cpu
    H -- "safetensors file" --> J["Memory-map file,<br/>slice tensor"]:::cpu
    H -- ".dat memmap" --> K["np.memmap →<br/>torch.tensor"]:::cpu

    I & J & K --> L["Copy weight to<br/>execution device (GPU)"]:::transfer
    L --> M{"More<br/>weights?"}:::decision
    M -- Yes --> F
    M -- No --> E

    E --> N["Module forward() executes<br/>All weights resident on execution device (GPU)"]:::gpu

    N --> O["post_forward hook fires"]:::hook
    O --> P{"Offloading<br/>enabled?"}:::decision
    P -- Yes --> Q["Loop over module weights"]:::process
    Q --> R["Replace weight with<br/>meta tensor — memory freed"]:::evict
    R --> S{"More<br/>weights?"}:::decision
    S -- Yes --> Q
    S -- No --> T
    P -- No --> T

    T{"Return output to<br/>original device?"}:::decision
    T -- Yes --> U["Move output to<br/>input's device"]:::process
    T -- No --> V
    U --> V(["Return output"]):::finish

    classDef start    fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f,stroke-width:2px
    classDef finish   fill:#dcfce7,stroke:#22c55e,color:#14532d,stroke-width:2px
    classDef process  fill:#f0f4f8,stroke:#94a3b8,color:#1e293b,stroke-width:1.5px
    classDef hook     fill:#ede9fe,stroke:#7c3aed,color:#4c1d95,stroke-width:1.5px
    classDef decision fill:#f8f7f4,stroke:#94a3b8,color:#1e293b,stroke-width:1.5px
    classDef gpu      fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f,stroke-width:1.5px
    classDef cpu      fill:#dcfce7,stroke:#16a34a,color:#14532d,stroke-width:1.5px
    classDef transfer fill:#fef9c3,stroke:#ca8a04,color:#713f12,stroke-width:1.5px
    classDef evict    fill:#fee2e2,stroke:#ef4444,color:#7f1d1d,stroke-width:1.5px
    classDef lookup   fill:#f1f5f9,stroke:#94a3b8,color:#334155,stroke-width:1.5px
