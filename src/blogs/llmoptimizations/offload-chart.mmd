%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#1e1e2e", "primaryTextColor": "#cdd6f4", "primaryBorderColor": "#45475a", "lineColor": "#89b4fa", "secondaryColor": "#181825", "tertiaryColor": "#1e1e2e", "background": "#181825", "mainBkg": "#1e1e2e", "nodeBorder": "#45475a", "clusterBkg": "#181825", "titleColor": "#cdd6f4", "edgeLabelBackground": "#181825", "edgeLabelColor": "#cdd6f4"}}}%%
flowchart TD
    A(["User calls model&#40;input&#41;"]):::start --> B[Wrapped forward triggered]:::process
    B --> C[pre_forward hook]:::hook

    C --> D{offload = True?}:::decision
    D -- No --> E[Send inputs to execution_device]:::process
    D -- Yes --> F[Iterate module parameters]:::process

    F --> G["weights_map&#91;name&#93;"]:::lookup
    G --> H{Source?}:::decision
    H -- CPU state_dict --> I[Return tensor from RAM]:::cpu
    H -- safetensors file --> J[safe_open → load tensor]:::cpu
    H -- .dat memmap --> K[np.memmap → torch.tensor]:::cpu

    I & J & K --> L["set_module_tensor_to_device<br/>meta → execution_device"]:::transfer
    L --> M{More params?}:::decision
    M -- Yes --> F
    M -- No --> E

    E --> N["Original forward&#40;&#41; runs on GPU<br/>all weights resident in VRAM"]:::gpu

    N --> O[post_forward hook]:::hook
    O --> P{offload = True?}:::decision
    P -- Yes --> Q[Iterate module parameters]:::process
    Q --> R["set_module_tensor_to_device<br/>execution_device → meta<br/>VRAM freed"]:::evict
    R --> S{More params?}:::decision
    S -- Yes --> Q
    S -- No --> T
    P -- No --> T

    T{io_same_device?}:::decision
    T -- Yes --> U["Send output back<br/>to original input device"]:::process
    T -- No --> V
    U --> V(["Return output"]):::finish

    classDef start    fill:#313244,stroke:#89b4fa,color:#89b4fa,stroke-width:2px
    classDef finish   fill:#313244,stroke:#a6e3a1,color:#a6e3a1,stroke-width:2px
    classDef process  fill:#1e1e2e,stroke:#45475a,color:#cdd6f4,stroke-width:1.5px
    classDef hook     fill:#2a1f3d,stroke:#cba6f7,color:#cba6f7,stroke-width:1.5px
    classDef decision fill:#1e1e2e,stroke:#cba6f7,color:#cdd6f4,stroke-width:1.5px
    classDef gpu      fill:#1e3a5f,stroke:#89b4fa,color:#cdd6f4,stroke-width:1.5px
    classDef cpu      fill:#1a3a2a,stroke:#a6e3a1,color:#cdd6f4,stroke-width:1.5px
    classDef transfer fill:#3a2a00,stroke:#f9e2af,color:#f9e2af,stroke-width:1.5px
    classDef evict    fill:#3a1a1a,stroke:#f38ba8,color:#f38ba8,stroke-width:1.5px
    classDef lookup   fill:#181825,stroke:#6c7086,color:#bac2de,stroke-width:1.5px

