flowchart TD
    LLM["<b>LLM</b><br/>Python entry point<br/>tensorrt_llm/llmapi/llm.py"]

    CFG["<b>KvCacheConfig</b><br/>freeGpuMemoryFraction · maxTokens<br/>enableBlockReuse · hostCacheSize<br/>onboardBlocks · crossKvCacheReuse"]

    KVM["<b>KVCacheManager</b><br/>cpp/include/.../batch_manager/kvCacheManager.h<br/>owns all WindowBlockManagers<br/>routes requests by (numKvHeads, windowSize)"]

    WBM1["<b>WindowBlockManager A</b><br/>numKvHeads=32 · windowSize=∞<br/>standard full-context window"]

    WBM2["<b>WindowBlockManager B</b><br/>numKvHeads=8 · windowSize=4096<br/>sliding-window attention variant"]

    KVBA["<b>KVBlockArray</b><br/>kvCacheUtils.h · paged path<br/>index table: batch × windows × 2 × max blocks per sequence<br/>getKBlockPtr / getVBlockPtr per token"]

    KVLB["<b>KVLinearBuffer</b><br/>kvCacheUtils.h · contiguous path<br/>flat tensor: batch × 2 × heads × sequence length × head dim<br/>used when paging is disabled"]

    GPU1["<b>GPU Primary Pool</b><br/>KVCacheBlockPool::primaryPtr<br/>shape: max blocks × layers × 2 × heads × tokens per block × head dim"]

    CPU1["<b>CPU Secondary Pool</b><br/>KVCacheBlockPool::secondaryPtr<br/>pinned host memory for offloaded blocks"]

    LLM -->|"reads"| CFG
    CFG -->|"configures"| KVM
    KVM -->|"creates"| WBM1
    KVM -->|"creates"| WBM2
    WBM1 -->|"indexes into"| KVBA
    WBM2 -->|"indexes into"| KVBA
    KVBA -->|"backed by"| GPU1
    KVLB -->|"backed by"| GPU1
    GPU1 -->|"offload path"| CPU1

